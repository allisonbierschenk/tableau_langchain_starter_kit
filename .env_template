# Model Providers
OPENAI_API_KEY='from OpenAI developer portal'
MODEL_PROVIDER='openai'

# LangSmith
LANGCHAIN_TRACING='true'
LANGCHAIN_API_KEY="from Langsmith app"
LANGCHAIN_PROJECT="Enter a name for your project, can be deleted but will show as 'Default' on LangSmith"

# MCP Servers (required)
MCP_SERVER_URL='https://your-mcp-server.example.com/tableau-mcp'
ADMIN_MCP_SERVER='https://your-admin-mcp-server.example.com/tableau-mcp'

# Optional second MCP (Slack) — same JSON-RPC+SSE transport as Tableau MCP
# SLACK_MCP_SERVER='https://mcp.slack.com/mcp'
# Server-side auth (Cursor OAuth does not apply here). Use one of:
# SLACK_MCP_BEARER_TOKEN='Bearer …'   # or raw token; Bearer prefix added if missing
# SLACK_MCP_AUTH_HEADER='X-Custom-Auth' + SLACK_MCP_AUTH_VALUE='…'
# Optional: pin Slack email lookup tool from tools/list
# SLACK_MCP_EMAIL_LOOKUP_TOOL='…'
# SLACK_MCP_EMAIL_ARGUMENT='email'

# MCP Authentication - Per-User Identity Mapping (optional)
# For direct-trust + per-request user authentication:
# Set this header name to pass Tableau username per request
# Example: X-Tableau-Jwt-Username
# Only use with network-protected MCP endpoints (VPN, private link, mTLS)
MCP_JWT_SUB_CLAIM_HEADER='X-Tableau-Jwt-Username'

# Tool Filtering (optional) - Restrict which MCP tools are available
# Comma-separated list of tool names or groups
# INCLUDE_TOOLS='admin-users,admin-groups,content-permissions'
# EXCLUDE_TOOLS='archive-workbook'
# INCLUDE_TOOL_GROUPS='admin,operations'
# EXCLUDE_TOOL_GROUPS='dangerous'

# Tableau Server / Cloud
TABLEAU_DOMAIN='your Tableau Cloud or Server domain'
TABLEAU_DOMAIN_FULL='your Tableau Cloud or Server domain with https://'
TABLEAU_SITE='your Tableau site'
# Optional: site LUID for REST path / MCP siteId when the model passes TABLEAU_SITE content name (Add User to Site)
# TABLEAU_SITE_LUID='xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx'

# MCP_DEBUG_LOG_ADMIN_USERS_SCHEMA='1'   # logs admin-users inputSchema at startup
TABLEAU_JWT_CLIENT_ID='from Connected App configuration page'
TABLEAU_JWT_SECRET_ID='from Connected App configuration page'
TABLEAU_JWT_SECRET='from Connected App configuration page'
TABLEAU_API_VERSION='3.21'
TABLEAU_USER='user account for the Agent'
DATASOURCE_LUID='unique identifier for a data source found via the graphql metadata API'

# Admin Portal Security
SESSION_SECRET='generate with: python -c "import secrets; print(secrets.token_hex(32))"'